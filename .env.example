# Copy this file to .env and fill in your own values.

# Port the server listens on.
PORT=3000

# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Web application).
# Authorized JavaScript origin must include http://localhost:3000 (or whatever PORT you use).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Only this Gmail address is allowed to sign in and access the data.
ALLOWED_EMAIL=you@gmail.com

# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string
