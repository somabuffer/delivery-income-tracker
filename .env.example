# Copy this file to .env and fill in your own values.

# Port the server listens on.
PORT=3000

# From the Clerk Dashboard (https://dashboard.clerk.com) > your application > API Keys.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Only this email address is allowed to access the data, regardless of how many
# accounts can sign in through Clerk.
ALLOWED_EMAIL=you@example.com

# Optional. Directory where data.json is stored. Leave unset for local dev (uses ./data).
# On Render this is set to /data automatically via render.yaml (the mounted persistent disk).
# DATA_DIR=/data

# Optional. If set, data is stored in Redis (Vercel KV / Upstash) instead of a JSON
# file, which is required on Vercel since its filesystem isn't persistent. Vercel
# injects these automatically once a KV/Upstash Redis database is connected to the
# project (Project > Storage > Create Database). Not needed on Render/local dev.
# KV_REST_API_URL=https://xxxxx.upstash.io
# KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
